# Copy to keystore.properties (gitignored) after generating the keystore:
#   keytool -genkeypair -v -keystore keystore.jks -alias hapanel \
#     -keyalg RSA -keysize 4096 -validity 10950
#
# The signing certificate's hash is baked into every provisioning QR —
# NEVER rotate or lose this keystore. Back it up somewhere safe.
storeFile=keystore.jks
storePassword=changeme
keyAlias=hapanel
keyPassword=changeme

# Copy to local.env and fill in. local.env is gitignored — it holds Wi-Fi credentials.

# Wi-Fi the panel joins during provisioning (WPA/WPA2).
WIFI_SSID="MyNetwork"
WIFI_PASSWORD="secret"

# Where the setup wizard downloads the DPC APK from — the latest GitHub
# release (must be publicly downloadable; see README step 2).
DPC_APK_URL="https://github.com/yepzdk/ha-panel-dpc/releases/latest/download/ha-panel-dpc.apk"

# HA Companion APK the DPC installs. Leave as-is for the latest minimal build.
HA_APK_URL="https://github.com/home-assistant/android/releases/latest/download/app-minimal-release.apk"

# Keystore used to sign the release APK (for the signature checksum).
KEYSTORE="../keystore.jks"
KEY_ALIAS="hapanel"
